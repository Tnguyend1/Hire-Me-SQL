# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Never commit Gradle wrapper cache accidentally copied into the project (~GB)
/wrapper/

# Gradle/Android caches accidentally created at repo root (can be ~2GB)
/caches/
android/.gradle/

# Gradle/Kotlin tooling accidentally created under repo root (not source code)
/daemon/
/kotlin-profile/
/native/

# Junk / local test artifacts
android/FakeDependency.jar
